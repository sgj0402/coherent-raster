+    def rasterize_splats_CR(
+        self,
+        adjacent_viewmats: Tensor,
+        Ks: Tensor,
+        view_idx_matrix: Tensor,
+        subpixel_coord_matrix: Tensor,
+        width: int,
+        height: int,
+        rasterize_mode: Optional[Literal["classic", "antialiased"]] = None,
+        camera_model: Optional[Literal["pinhole", "ortho", "fisheye"]] = None,
+        is_debug: bool = False,
+        backgrounds=None,
+        **kwargs,
+    ) -> Tuple[Tensor, Tensor, Dict]:
+        means = self.splats["means"]  # [N, 3]
+        # quats = F.normalize(self.splats["quats"], dim=-1)  # [N, 4]
+        # rasterization does normalization internally
+        quats = self.splats["quats"]  # [N, 4]
+        scales = torch.exp(self.splats["scales"])  # [N, 3]
+        opacities = torch.sigmoid(self.splats["opacities"])  # [N,]
+        
+        colors = torch.cat([self.splats["sh0"], self.splats["shN"]], 1)  # [N, K, 3]
+
+        if rasterize_mode is None:
+            rasterize_mode = "antialiased" if self.cfg.antialiased else "classic"
+        if camera_model is None:
+            camera_model = self.cfg.camera_model
+        
+        render_colors, render_alphas, info = rasterization_CR(
+            means=means,
+            quats=quats,
+            scales=scales,
+            opacities=opacities,
+            colors=colors,
+            adjacent_viewmats=adjacent_viewmats, # [num_of_viewgroup, view_group_size, 4, 4]
+            Ks=Ks,  # [C, 3, 3]
+            view_idx_matrix=view_idx_matrix,
+            subpixel_coord_matrix=subpixel_coord_matrix,
+            width=width,
+            height=height,
+            packed=self.cfg.packed,
+            absgrad=(
+                self.cfg.strategy.absgrad
+                if isinstance(self.cfg.strategy, DefaultStrategy)
+                else False
+            ),
+            sparse_grad=self.cfg.sparse_grad,
+            rasterize_mode=rasterize_mode,
+            camera_model=self.cfg.camera_model,
+            is_debug=is_debug,
+            backgrounds=backgrounds,
+            **kwargs,
+        )
+
+        return render_colors, render_alphas, info
+
