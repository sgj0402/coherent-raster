+            colors = unpatchify_image_shape_matrix(colors)
+            colors = unpad(colors, self.target_height, self.target_width)
+            colors = colors.permute(1, 2, 0)
+            colors = torch.clamp(colors, 0.0, 1.0)
+            torch.cuda.synchronize()
+
+            if iter >= cfg.warmup_iter:
+                fps_time += max(time.time() - tic, 1e-10)
+                counter += 1
