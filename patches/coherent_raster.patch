+    @torch.no_grad()
+    def _viewer_render_fn(
+        self, camera_state: CameraState, render_tab_state: RenderTabState
+    ):
+        # gsplat viewer is only used for camera input control
+        return None
+    
+    def run_native_viewer_loop(self):
+        """
+        - Stats are calculated form the PREVIOUS interval to avoid causality loops.
+        """
+        print("[Native Viewer] Starting Demo Loop...")
+        print("[Key Guide] Press 'F11' to toggle full-screen mode. Press 'P' to toggle Profiling Mode.")
+
+        if not hasattr(self, "native_viewer") or self.native_viewer is None:
+            self.native_viewer = ZeroCopyGLViewer(self.target_width, self.target_height)
+        
+        if not hasattr(self, "server"):
+            print("Viser Server not initialized!")
+            return
+
+        self.output_buffer = torch.zeros(
+            (self.target_height, self.target_width, 3), 
+            dtype=torch.uint8, 
+            device=self.device
+        )
+        
+        self.float_buffer = torch.zeros(
+            (self.target_height, self.target_width, 3), 
+            dtype=torch.float32, 
+            device=self.device
+        )
+
+        frame_counter = 0
+        last_ui_update_time = time.perf_counter()
+        last_frame_time = last_ui_update_time
+        
+        fps_text = "Initializing..."
+        
+        avg_fps = 0.0
+        avg_render_ms = 0.0
+        avg_display_ms = 0.0
+
+        accum_render_time = 0.0
+        accum_display_time = 0.0
+        
+        is_profiling = False
+        p_key_pressed = False
+
+        total_vram = torch.cuda.get_device_properties(self.device).total_memory
+        memory_threshold_ratio = 0.9  # if over 90%, empty cache
+
+        while True:
+            loop_start = time.perf_counter()
+
+            if glfw.get_key(self.native_viewer.window, glfw.KEY_P) == glfw.PRESS:
+                if not p_key_pressed:
+                    is_profiling = not is_profiling
+
+                    frame_counter = 0
+                    last_ui_update_time = loop_start
+                    fps_text = "Mode Switched..."
+                    p_key_pressed = True
+            else:
+                p_key_pressed = False
+
+            clients = list(self.server.get_clients().values())
+            if not clients:
+                time.sleep(0.001)
+                continue
+            
+            client = clients[0]
+            camera = client.camera
+
+            rotation_matrix = R.from_quat([camera.wxyz[1], camera.wxyz[2], camera.wxyz[3], camera.wxyz[0]]).as_matrix()
+            c2w_np = np.eye(4, dtype=np.float32)
+            c2w_np[:3, :3] = rotation_matrix
+            c2w_np[:3, 3] = camera.position
+            c2w = torch.from_numpy(c2w_np).to(device=self.device, non_blocking=True)
+
+            # viewer tab states
+            viewer_config = self.viewer.viewer_config
+
+            orbit_center = get_dynamic_orbit_center(c2w, distance=viewer_config.orbit_center_distance)
+            viewmats_batch = self.synthesize_viewmats(c2w, orbit_center)
+            
+            
+            t_render_start = 0.0
+            if is_profiling:
+                torch.cuda.synchronize()
+                t_render_start = time.perf_counter()
+            
+            with torch.no_grad():
+                colors, _, _ = self.rasterize_splats_CR(
+                adjacent_viewmats=viewmats_batch,
+                Ks=self.K_scaled.unsqueeze(0),
+                view_idx_matrix=self.viewpoint_index_matrix_patchified,
+                subpixel_coord_matrix=self.subpixel_coord_matrix_patchified,
+                width=self.target_width,
+                height=self.target_height,
+                sh_degree=cfg.sh_degree,
+                near_plane=cfg.near_plane,
+                far_plane=cfg.far_plane,
+                backgrounds=self.fixed_bg_tensor
+                )  # [3, H, W]
+            
+            colors = unpatchify_image_shape_matrix(colors)
+            colors = unpad(colors, self.target_height, self.target_width) # [3, H, W]
+            
+            t_render_end = 0.0
+            if is_profiling:
+                torch.cuda.synchronize()
+                t_render_end = time.perf_counter()
+                accum_render_time += (t_render_end - t_render_start)
+
+            t_display_start = 0.0
+            if is_profiling:
+                t_display_start = time.perf_counter() 
+
+            self.float_buffer.copy_(colors.permute(1, 2, 0))
+            
+            self.float_buffer.clamp_(0.0, 1.0)
+            self.float_buffer.mul_(255.0)
+            
+            self.output_buffer.copy_(self.float_buffer.to(torch.uint8))
+
+
+            if frame_counter % 10 == 0:
+                if is_profiling:
+                    fps_text = (
+                        f"[PROFILE]\n"
+                        f"FPS: {avg_fps:.1f}\n"
+                        f"Render: {avg_render_ms:.2f}ms\n"
+                        f"Display: {avg_display_ms:.2f}ms\n"
+                        f"FrameTime: {(loop_start - last_frame_time)*1000:.2f}ms"
+                    )
+                else:
+                    fps_text = f"[VIEW]\nFPS: {avg_fps:.1f}"
+
+            if not self.native_viewer.update(self.output_buffer, overlay_text=fps_text):
+                print("[Native Viewer] Closed.")
+                break
+            
+            t_display_end = 0.0
+            if is_profiling:
+                torch.cuda.synchronize() 
+                t_display_end = time.perf_counter()
+                accum_display_time += (t_display_end - t_display_start)
+
+            frame_counter += 1
+            current_time = time.perf_counter()
+            if current_time - last_ui_update_time >= 1:
+                avg_fps = frame_counter / (current_time - last_ui_update_time)
+                
+                if is_profiling:
+                    avg_render_ms = (accum_render_time / frame_counter) * 1000
+                    avg_display_ms = (accum_display_time / frame_counter) * 1000
+                    
+                    accum_render_time = 0.0
+                    accum_display_time = 0.0
+                
+                frame_counter = 0
+                last_ui_update_time = current_time
+
+            last_frame_time = loop_start
+
+            current_reserved = torch.cuda.memory_reserved(self.device)
+
+            if current_reserved / total_vram > memory_threshold_ratio:
+                print(f"[Memory] High usage detected ({current_reserved/1024**3:.2f} GB). Clearing cache...")
+                torch.cuda.empty_cache()
+
+    
+    def synthesize_viewmats(self, c2w, orbit_center):
+        R_orig = c2w[:3, :3]
+        t_orig = c2w[:3, 3]
+        
+        u = R_orig[:, 1] # Up vector
+        
+        # Skew-Symmetric Matrix
+        R_skew = torch.zeros((3, 3), device=self.device)
+        R_skew[0, 1], R_skew[0, 2] = -u[2], u[1]
+        R_skew[1, 0], R_skew[1, 2] =  u[2], -u[0]
+        R_skew[2, 0], R_skew[2, 1] = -u[1], u[0]
+        R_skew = R_skew.unsqueeze(0)
+        
+        R_skew_sq = torch.matmul(R_skew, R_skew)
+
+        # Rodrigues Formula
+        R_rot_batch = (
+            self.identity_3x3 + 
+            self.sin_vals * R_skew + 
+            self.one_minus_cos * R_skew_sq
+        )
+
+        rel_pos = (t_orig - orbit_center).view(1, 3, 1)
+        new_rel_pos = torch.matmul(R_rot_batch, rel_pos)
+        
+        new_t = orbit_center.view(1, 3) + new_rel_pos.squeeze(-1)
+        new_R = torch.matmul(R_rot_batch, R_orig.unsqueeze(0))
+
+        # c2w -> w2c (Inverse)
+        w2c_R = new_R.transpose(1, 2)
+        w2c_t = -torch.matmul(w2c_R, new_t.unsqueeze(-1)).squeeze(-1)
+
+
+        self.viewmats_buffer[:self.n_valid_views, :3, :3] = w2c_R
+        self.viewmats_buffer[:self.n_valid_views, :3, 3]  = w2c_t
+        
+        if self.n_pad_camera > 0:
+            self.viewmats_buffer[self.n_valid_views:, :3, :3] = w2c_R[-1]
+            self.viewmats_buffer[self.n_valid_views:, :3, 3]  = w2c_t[-1]
+
+        viewmats_batch = self.viewmats_buffer.view(
+            self.n_cluster, self.cfg.cluster_size, 4, 4
+        )
+        
+        return viewmats_batch
+
