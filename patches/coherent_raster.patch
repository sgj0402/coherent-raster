+
+
+        counter = 0
+        fps_time = 0
+
+        for iter in tqdm.tqdm(range(cfg.warmup_iter + cfg.measure_iter)):
+
+            torch.cuda.synchronize()
+            tic = time.time()
+            colors, _, _ = self.rasterize_splats_CR(
+                adjacent_viewmats=self.synthesized_viewmats_clustered,
+                Ks=self.K_scaled.unsqueeze(0),
